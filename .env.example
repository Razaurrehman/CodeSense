OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=codellama:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=codebase_index

POSTGRES_URL=postgresql+asyncpg://codeagent:codeagent@postgres:5432/codeagent

REDIS_URL=redis://redis:6379/0

GIT_TOKEN=your_github_pat_here

# GitHub OAuth App (for the UI login)
# Create one at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:        http://localhost:5174
# Callback URL:        http://localhost:8080/api/v1/auth/callback
GITHUB_CLIENT_ID=your_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_oauth_app_client_secret

GROQ_API_KEY=
ALERT_WEBHOOK_URL=

REPOS_CONFIG_PATH=/config/repos.yaml
LOG_LEVEL=INFO
